    "The proxy used by the following routing rules was deleted. They have been reset to Default: %@" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تم حذف البروكسي المستخدم في قواعد التوجيه التالية. تمت إعادة تعيينها إلى الافتراضي: %@"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The proxy used by the following routing rules was deleted. They have been reset to Default: %@"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se eliminó el proxy utilizado por las siguientes reglas de enrutamiento. Se han restablecido a Predeterminado: %@"
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "پروکسی استفاده‌شده در قوانین مسیریابی زیر حذف شد. آن‌ها به پیش‌فرض بازنشانی شده‌اند: %@"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Прокси, используемый следующими правилами маршрутизации, был удалён. Они сброшены на значение по умолчанию: %@"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aşağıdaki yönlendirme kurallarında kullanılan proxy silindi. Varsayılana sıfırlandılar: %@"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Proxy được sử dụng bởi các quy tắc định tuyến sau đã bị xóa. Chúng đã được đặt lại về Mặc định: %@"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "以下路由规则使用的代理已被删除，它们已重置为默认: %@"
          }
        }
      }
    },
    "This will skip TLS certificate validation, making your connections vulnerable to MITM attacks." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "سيؤدي هذا إلى تخطي التحقق من شهادة TLS، مما يجعل اتصالاتك عرضة لهجمات الوسيط."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This will skip TLS certificate validation, making your connections vulnerable to MITM attacks."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esto omitirá la validación del certificado TLS, haciendo que tus conexiones sean vulnerables a ataques MITM."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "این کار اعتبارسنجی گواهی TLS را رد می‌کند و اتصالات شما را در برابر حملات MITM آسیب‌پذیر می‌کند."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Это пропустит проверку сертификата TLS, делая ваши соединения уязвимыми для MITM-атак."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bu, TLS sertifika doğrulamasını atlayarak bağlantılarınızı MITM saldırılarına karşı savunmasız hale getirir."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Thao tác này sẽ bỏ qua xác thực chứng chỉ TLS, khiến kết nối của bạn dễ bị tấn công MITM."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "这将跳过 TLS 证书验证，使您的连接容易受到中间人攻击。"
          }
        }
      }
    },
