    "Packet Up" : {
      "shouldTranslate" : false
    },
    "Packets sent to a reflection address are returned to their sender instead of being routed or proxied." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تُعاد الحِزَم المُرسَلة إلى عنوان انعكاس إلى مُرسِلها بدلاً من توجيهها أو تمريرها عبر الوكيل."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Packets sent to a reflection address are returned to their sender instead of being routed or proxied."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los paquetes enviados a una dirección de reflexión se devuelven al remitente en lugar de enrutarse o pasar por el proxy."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "بسته‌های ارسال‌شده به یک آدرس بازتاب، به‌جای مسیریابی یا عبور از پراکسی، به فرستنده‌شان بازگردانده می‌شوند."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Пакеты, отправленные на адрес отражения, возвращаются отправителю вместо маршрутизации или проксирования."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bir yansıma adresine gönderilen paketler yönlendirilmek veya proxy üzerinden geçirilmek yerine gönderenine geri döndürülür."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Các gói tin được gửi đến địa chỉ phản chiếu sẽ được trả lại cho người gửi thay vì được định tuyến hoặc đi qua proxy."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "发送到反射地址的数据包会被退回给发送方，而不会进行路由或代理。"
          }
        }
      }
    },
