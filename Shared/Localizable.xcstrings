    "Any previously installed MITM profile will stop working until you re-install the new certificate." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "سيتوقف أي ملف تعريف MITM مثبت سابقًا عن العمل حتى تعيد تثبيت الشهادة الجديدة."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Any previously installed MITM profile will stop working until you re-install the new certificate."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cualquier perfil MITM previamente instalado dejará de funcionar hasta que reinstales el nuevo certificado."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "هر پروفایل MITM که قبلاً نصب شده باشد، تا زمانی که گواهی جدید را دوباره نصب نکنید، کار نخواهد کرد."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Любой ранее установленный профиль MITM перестанет работать, пока вы не переустановите новый сертификат."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Önceden yüklenmiş herhangi bir MITM profili, yeni sertifikayı yeniden yükleyene kadar çalışmayacaktır."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mọi hồ sơ MITM đã cài đặt trước đó sẽ ngừng hoạt động cho đến khi bạn cài đặt lại chứng chỉ mới."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "任何之前安装的 MITM 描述文件都将停止工作直到你重新安装一份新的证书。"
          }
        }
      }
    },
